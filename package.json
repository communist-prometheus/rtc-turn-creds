{
  "name": "@rtc-less/turn-creds",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "TURN credential server for WebRTC NAT traversal",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "dev": "bun --hot src/dev.ts",
    "lint": "biome ci .",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.6.0",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
