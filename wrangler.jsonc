{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rtc-turn-creds",
  "main": "src/worker.ts",
  "compatibility_date": "2024-12-01",
  "vars": {
    "TURN_SERVERS": "turn.comprom.org"
  }
  // Secrets (set via wrangler secret put):
  // TURN_SHARED_SECRET — for HMAC-SHA1 when coturn uses use-auth-secret
  // TURN_STATIC_USER — temporary static username
  // TURN_STATIC_PASS — temporary static password
}
